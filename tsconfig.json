{
  "extends": ["@tsconfig/node22/tsconfig.json", "@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    // Re-list @tsconfig/node22's libs (lib replaces, doesn't merge) plus DOM, so
    // puppeteer browser-context callbacks (page.waitForFunction) can use DOM types.
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator", "DOM"]
  },
  "include": ["src/**/*.ts"]
}
